{
  "name": "skill-harness",
  "version": "0.1.0",
  "description": "A portable, tool-agnostic harness for LLM-powered development skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill": "./bin/skill"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "validate": "bun run bin/skill validate"
  },
  "keywords": [
    "llm",
    "ai",
    "skills",
    "methodology",
    "claude",
    "mcp"
  ],
  "author": "Zenb0t",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "commander": "^12.1.0",
    "yaml": "^2.4.5",
    "glob": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "bun-types": "^1.3.6",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
