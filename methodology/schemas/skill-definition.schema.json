{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "description", "inputs", "outputs", "tools"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Skill name in kebab-case"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Brief description of what this skill does"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "required", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "string[]", "object"]
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "default": {
            "description": "Default value if not provided"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["structured", "text", "markdown"]
        },
        "schema": {
          "type": "object",
          "description": "JSON Schema for structured output"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "read_file",
          "write_file",
          "list_directory",
          "find_files",
          "git_diff",
          "git_log",
          "git_status",
          "run_command"
        ]
      },
      "description": "Tools this skill is allowed to use"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "author": {
      "type": "string"
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input", "description"],
        "properties": {
          "input": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
