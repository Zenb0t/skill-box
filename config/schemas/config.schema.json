{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["llm", "context", "tools", "output"],
  "properties": {
    "llm": {
      "type": "object",
      "required": ["provider", "model", "api_key_env", "max_tokens"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["anthropic"]
        },
        "model": {
          "type": "string"
        },
        "api_key_env": {
          "type": "string"
        },
        "max_tokens": {
          "type": "number",
          "minimum": 1,
          "maximum": 200000
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "context": {
      "type": "object",
      "required": ["default_paths", "max_file_size", "max_total_context"],
      "properties": {
        "default_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_file_size": {
          "type": "number",
          "minimum": 0
        },
        "max_total_context": {
          "type": "number",
          "minimum": 0
        },
        "prioritization": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "weight"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["documentation", "guide", "code", "config"]
              },
              "weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "ttl": {
              "type": "number"
            },
            "watch": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "properties": {
        "shell": {
          "type": "object",
          "required": ["enabled", "allowed_commands", "timeout"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "require_confirmation": {
              "type": "boolean"
            },
            "dry_run_default": {
              "type": "boolean"
            },
            "allowed_commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "timeout": {
              "type": "number"
            },
            "sandbox": {
              "type": "object",
              "properties": {
                "network": {
                  "type": "boolean"
                },
                "filesystem_write": {
                  "type": "boolean"
                },
                "root_directory": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["format", "color"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["markdown", "json", "plain"]
        },
        "color": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        },
        "show_reasoning": {
          "type": "boolean"
        }
      }
    },
    "session": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storage": {
          "type": "string"
        },
        "ttl": {
          "type": "number"
        }
      }
    }
  }
}
